###
POST {{baseUrl}}/validation/v1/modifications/rules?class=ch.ti8m.egov.demo.Geschaeft.class
Content-Type: application/text

Die ID des Urhebers muss grösser sein als null.

> {%
    client.test("Create a new book", function () {
        client.assert(response.status === 200, "Response status is " + response.status)
        client.global.set("rule", JSON.stringify(response.body))
    })
%}

###
POST {{baseUrl}}/validation/v1/modifications/rules/apply?class=ch.ti8m.egov.demo.Geschaeft.class&field=urheber.id
Content-Type: application/json

{
"rule": {{ rule }}
}

> {%
    client.test("Create a new book", function () {
        client.assert(response.status === 200, "Response status is " + response.status)
    })
%}

